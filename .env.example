# ── Upcells environment configuration ──────────────────────────────────────────
# Copy this file to `.env` and fill in your values. `.env` is git-ignored.

# ── Development ─────────────────────────────────────────────────────────────

# Set to "true" to skip the license gate entirely during development.
# Must be absent or "false" for release builds.
VITE_SKIP_LICENSE=true

# ── Licensing (Keygen.sh) ───────────────────────────────────────────────────
# Required for release builds. Get these from your Keygen dashboard:
# https://app.keygen.sh/

VITE_KEYGEN_ACCOUNT_ID=your-keygen-account-id-here
VITE_KEYGEN_PRODUCT_ID=your-keygen-product-id-here

# Keygen Ed25519 public key for offline signature verification (hex).
# Only needed if you later enable offline license signing — optional for v1.
VITE_KEYGEN_PUBLIC_KEY=

# ── macOS code-signing (release only) ───────────────────────────────────────
# Tauri picks these up automatically from the environment when running
# `npm run tauri:build`. Leave unset for dev builds; required for DMG
# notarisation so Gatekeeper doesn't block the app on customer machines.
#
#   APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"
#   APPLE_ID="your.apple.id@example.com"
#   APPLE_PASSWORD="app-specific-password-from-appleid.apple.com"
#   APPLE_TEAM_ID="XXXXXXXXXX"
#
# Usually set in your shell profile or CI secrets — keep them out of
# committed config.

# ── Windows code-signing (release only) ─────────────────────────────────────
# Tauri v2 reads these from the environment:
#
#   TAURI_SIGNING_PRIVATE_KEY=<base64 of your .p12 content>
#   TAURI_SIGNING_PRIVATE_KEY_PASSWORD=<p12 password>
#
# Or configure `bundle.windows.certificateThumbprint` in tauri.conf.json
# to use an installed code-signing certificate by thumbprint.
